# =============================================================================
# LLM Configuration
# =============================================================================
# Option A: OpenAI
#   OPENAI_API_KEY=sk-proj-your-key-here
#   OPENAI_MODEL=gpt-4o
#
# Option B: Self-hosted / OpenAI-compatible (vLLM, Ollama, RunPod)
#   LLM_BASE_URL=https://your-endpoint/v1
#   LLM_API_KEY=your-api-key
#   LLM_MODEL=nemotron-2-30B-A3B
#
# LLM_MODEL must match an id from the provider (wrong name → HTTP 404 from the LLM API).
# Example check: curl -sS "${LLM_BASE_URL%/v1}/v1/models" -H "Authorization: Bearer $LLM_API_KEY"

LLM_BASE_URL=https://your-endpoint/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name

# =============================================================================
# Embedding Configuration
# =============================================================================
# Option A: Local (no API key needed — runs on server CPU)
#   EMBEDDING_PROVIDER=local
#   EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
#   EMBEDDING_DIMENSIONS=1024
#
# Option B: OpenAI
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-proj-your-key-here
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_DIMENSIONS=1536

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# =============================================================================
# Neo4j
# =============================================================================
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j

# =============================================================================
# Cypher query log (optional — defaults under <project>/data/logs/)
# =============================================================================
# If logs land in the wrong folder (e.g. site-packages), set the deploy root:
# CHATBOT_PROJECT_ROOT=/opt/chatbot
# CYPHER_LOG_PATH=/opt/chatbot/data/logs/cypher_queries.log
# CYPHER_LOG_MAX_BYTES=5242880

# =============================================================================
# Optional: Tavily (web search)
# =============================================================================
# TAVILY_API_KEY=tvly-your-key-here
