# =============================================================================
# LLM Configuration
# =============================================================================
# Option A: OpenAI
#   OPENAI_API_KEY=sk-proj-your-key-here
#   OPENAI_MODEL=gpt-4o
#
# Option B: Self-hosted / OpenAI-compatible (vLLM, Ollama, RunPod)
#   LLM_BASE_URL=https://your-endpoint/v1
#   LLM_API_KEY=your-api-key
#   LLM_MODEL=qwen2.5-32b
#
# LLM_MODEL must match an id from the provider (wrong name → HTTP 404 from the LLM API).
# Example check: curl -sS "${LLM_BASE_URL%/v1}/v1/models" -H "Authorization: Bearer $LLM_API_KEY"

LLM_BASE_URL=https://m3vke16xgzhstu-8000.proxy.runpod.net/v1
LLM_API_KEY=your-api-key
LLM_MODEL=qwen2.5-32b
# Timeout singola richiesta chat LLM (secondi)
LLM_REQUEST_TIMEOUT_SECONDS=60
# Retry su errori/transient upstream LLM
LLM_MAX_RETRIES=1
# Fallback applicativo extra (oltre ai retry client OpenAI)
LLM_FALLBACK_ATTEMPTS=3
LLM_FALLBACK_BASE_DELAY_SECONDS=0.8
# If true, create a new ChatOpenAI client for every LLM call (no shared HTTP session reuse).
LLM_FRESH_CLIENT_PER_CALL=false
# If true, create a new structured-output LLM client for each entity-extraction call.
LLM_ENTITY_FRESH_CLIENT_PER_CALL=false

# Small context models (e.g. 16k total): uncapped JSON entity extraction can hit the window limit,
# truncate mid-response, and LangChain raises "Could not parse response content as the length limit was reached".
# Cap structured entity graph JSON output (default in code: 16384 = 16k; lower if the total context is small):
# LLM_ENTITY_EXTRACTION_MAX_TOKENS=16384
# Optional cap for all other chat completions (synthesis, query rewrite, …):
# LLM_MAX_OUTPUT_TOKENS=8192

# =============================================================================
# Embedding Configuration
# =============================================================================
# Option A: Local (no API key needed — runs on server CPU)
#   EMBEDDING_PROVIDER=local
#   EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
#   EMBEDDING_DIMENSIONS=1024
#
# Option B: OpenAI
#   EMBEDDING_PROVIDER=openai
#   OPENAI_API_KEY=sk-proj-your-key-here
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_DIMENSIONS=1536

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# =============================================================================
# Neo4j
# =============================================================================
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j
# Timeout connessione al driver Neo4j
NEO4J_CONNECTION_TIMEOUT_SECONDS=20
# Riciclo connessioni pool
NEO4J_MAX_CONNECTION_LIFETIME_SECONDS=1800

# Timeout complessivo endpoint /api/chat (FastAPI) prima di rispondere 504
CHAT_ENDPOINT_TIMEOUT_SECONDS=600

# Language detect in session chat:
# false = salta detection e forza session_language=it (fase attuale)
CHAT_ENABLE_LANGUAGE_DETECT=false
# Lingua default sessione (usata se detect disattivato)
CHAT_DEFAULT_LANGUAGE=it

# Context retrieval:
# false = usa query/generalized query reale
# true  = usa una frase fissa per recuperare contesto (bypass temporaneo)
RAG_USE_DEFAULT_CONTEXT=false
RAG_DEFAULT_CONTEXT_QUERY=leggi italiane

# Cypher optimization:
# true  = usa LLM per generalized query + keyword extraction
# false = usa direttamente la frase utente come generalized_query e keyword seed
CYPHER_OPTIMIZATION_ENABLED=true

# Decompose stage:
# true  = decompose_query usa LLM (generalizzazione + estrazione entità)
# false = bypass totale LLM in decompose_query (path deterministico)
DECOMPOSE_LLM_ENABLED=true

# Keyword extraction:
# true  = estrazione keyword da LLM
# false = usa keyword standard da config (RAG_DEFAULT_KEYWORDS)
KEYWORD_EXTRACTION_ENABLED=true
RAG_DEFAULT_KEYWORDS=normativa,legge,decreto

# =============================================================================
# Cypher query log (optional — defaults under <project>/data/logs/)
# =============================================================================
# If logs land in the wrong folder (e.g. site-packages), set the deploy root:
# CHATBOT_PROJECT_ROOT=/opt/chatbot
# CYPHER_LOG_PATH=/opt/chatbot/data/logs/cypher_queries.log
# CYPHER_LOG_MAX_BYTES=5242880

# =============================================================================
# Optional: Tavily (web search)
# =============================================================================
# TAVILY_API_KEY=tvly-your-key-here
