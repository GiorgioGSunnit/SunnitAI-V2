# =============================================================================
# SunnitAI ChatBot — Production env template (no secrets)
# =============================================================================
# Copia in .env sul server e compila i valori reali:
#   cp env.production.template .env && nano .env
#
# LLM_MODEL deve coincidere ESATTAMENTE con un id restituito da:
#   curl -sS "${LLM_BASE_URL%/v1}/v1/models" -H "Authorization: Bearer $LLM_API_KEY"
# (oppure l’endpoint equivalente del provider). Un nome sbagliato → 404 dal provider.
# =============================================================================

# LLM (endpoint compatibile OpenAI: vLLM, RunPod, Ollama, ecc.)
LLM_BASE_URL=https://your-endpoint.example/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=nemotron-2-30B-A3B

# Embeddings — locale sul server (nessuna API key)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# Neo4j
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
NEO4J_DATABASE=neo4j
